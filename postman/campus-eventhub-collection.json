{
  "info": {
    "_postman_id": "campus-eventhub-collection",
    "name": "Campus EventHub — All Services",
    "description": "Complete API collection for Campus EventHub microservices.\n\nImport the environment file `campus-eventhub-environment.json` alongside this collection.\n\n**Demo flow order:**\n1. Infrastructure — verify Eureka + Gateway\n2. Venue Service — create venue\n3. Event Service — create event, assign venue\n4. Registration Service — register student\n5. Ticket Service — fetch QR pass\n6. Notification Service — verify notification logged\n7. Attendance Service — mark attendance\n8. Certificate Service — download certificate\n9. Feedback Service — submit feedback\n10. Leaderboard Service — publish results\n11. Announcement Service — create announcement\n12. Resource Service — upload file\n13. Sponsor Service — add sponsor",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}" }
  ],
  "item": [

    {
      "name": "00 — Infrastructure",
      "item": [
        {
          "name": "Eureka Health",
          "request": {
            "method": "GET",
            "url": "{{eurekaUrl}}/actuator/health",
            "description": "Verify Eureka Server is UP"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is UP', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health",
            "description": "Verify API Gateway is UP"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is UP', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Eureka Registered Apps",
          "request": {
            "method": "GET",
            "url": "{{eurekaUrl}}/eureka/apps",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "List all services registered in Eureka"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "01 — Event Service",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/events",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Workshop\",\n  \"description\": \"Hands-on Spring Boot microservices workshop\",\n  \"eventDate\": \"2024-08-15T10:00:00\",\n  \"endDate\": \"2024-08-15T17:00:00\",\n  \"category\": \"WORKSHOP\",\n  \"maxCapacity\": 50\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));",
                  "pm.test('Status is UPCOMING', () => pm.expect(pm.response.json().status).to.eql('UPCOMING'));",
                  "pm.environment.set('eventId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Correct event returned', () => {",
                  "  pm.expect(pm.response.json().id).to.eql(Number(pm.environment.get('eventId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Events by Status — UPCOMING",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/status/UPCOMING"
          },
          "event": [
