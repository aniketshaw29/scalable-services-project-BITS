                  "  pm.response.json().forEach(e => pm.expect(e.status).to.eql('UPCOMING'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/events/{{eventId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Workshop — Updated\",\n  \"maxCapacity\": 60\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Title updated', () => pm.expect(pm.response.json().title).to.include('Updated'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Event by ID — 404",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
